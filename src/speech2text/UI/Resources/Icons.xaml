<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Idle state: blue circle + black microphone (32×32 canvas) -->
    <DrawingImage x:Key="AppIcon.Idle">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Blue circle background -->
                <GeometryDrawing Brush="#03A9F4">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="16,16" RadiusX="16" RadiusY="16"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Mic body (black capsule) -->
                <GeometryDrawing Brush="Black">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry RadiusX="3" RadiusY="3" Rect="13,7,6,10"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Mic stand (U-arch) -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="Black" Thickness="1.8" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry>
                            <PathFigure StartPoint="11,17" IsClosed="False">
                                <QuadraticBezierSegment Point1="11,21" Point2="16,21"/>
                                <QuadraticBezierSegment Point1="21,21" Point2="21,17"/>
                            </PathFigure>
                        </PathGeometry>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Stem -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="Black" Thickness="1.8" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <LineGeometry StartPoint="16,21" EndPoint="16,25"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Base -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="Black" Thickness="1.8" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <LineGeometry StartPoint="13,25" EndPoint="19,25"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
