<Window x:Class="speech2text.UI.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="speech2text"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- Outer border: rounded corners + drop shadow -->
    <Border CornerRadius="10" ClipToBounds="True"
            Background="{DynamicResource MaterialDesignPaper}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Direction="270" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <DockPanel MinWidth="280">

            <!-- ── Title bar (draggable) ── -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource PrimaryHueDarkBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Cursor="SizeAll">
                <Grid Height="42" Margin="14,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status dot -->
                    <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#60FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Fill" Value="#EF5350"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTranscribing}" Value="True">
                                        <Setter Property="Fill" Value="#FFA726"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <!-- Title + state -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="speech2text"
                                   Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                                   FontWeight="Medium" FontSize="13"/>
                        <TextBlock Text=" — "
                                   Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                                   Opacity="0.5" FontSize="12"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                                   Opacity="0.7" FontSize="12"/>
                    </StackPanel>

                    <!-- Minimize + Close -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Command="{Binding MinimizeCommand}"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                                Width="34" Height="42" Padding="0"
                                ToolTip="Minimize">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                        </Button>
                        <Button Command="{Binding CloseCommand}"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                                Width="34" Height="42" Padding="0"
                                ToolTip="Close">
                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Content ── -->
            <StackPanel Margin="16,14,16,16">

                <!-- Profile selector -->
                <TextBlock Text="PROFILE" FontSize="10" FontWeight="Medium" Opacity="0.45" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding ActiveProfile}"
                          DisplayMemberPath="Name"
                          Margin="0,0,0,14"/>

                <!-- Microphone selector -->
                <TextBlock Text="MICROPHONE" FontSize="10" FontWeight="Medium" Opacity="0.45" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding AudioDevices}"
                          SelectedItem="{Binding SelectedDevice}"
                          DisplayMemberPath="Name"
                          Margin="0,0,0,18"/>

                <!-- Recording toggle button -->
                <Button Command="{Binding ToggleRecordingCommand}"
                        HorizontalAlignment="Stretch"
                        Height="42"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Width="18" Height="18"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="Microphone"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Kind" Value="Stop"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                        <TextBlock Text="{Binding RecordingButtonLabel}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Settings button -->
                <Button Content="Settings"
                        Command="{Binding OpenSettingsCommand}"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        materialDesign:ButtonAssist.CornerRadius="6"/>

                <!-- Error panel -->
                <Border CornerRadius="6" Padding="10,8" Margin="0,10,0,0"
                        Background="#B71C1C"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding ErrorMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="White"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Command="{Binding DismissErrorCommand}"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Foreground="White"
                                Width="24" Height="24" Padding="0"
                                VerticalAlignment="Top"
                                Margin="6,0,0,0">
                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
        </DockPanel>
    </Border>
</Window>
