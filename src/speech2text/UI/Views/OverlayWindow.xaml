<Window x:Class="speech2text.UI.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="speech2text"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border CornerRadius="10" ClipToBounds="True"
            Background="{DynamicResource MaterialDesignPaper}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Direction="270" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <DockPanel MinWidth="440">

            <!-- ── Title bar (draggable) ── -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource PrimaryHueDarkBrush}"
                    Cursor="SizeAll">
                <Grid Height="34" Margin="12,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status dot -->
                    <Ellipse Grid.Column="0" Width="7" Height="7" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#55FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Fill" Value="#EF5350"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTranscribing}" Value="True">
                                        <Setter Property="Fill" Value="#FFA726"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <!-- Title + state -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="speech2text"
                                   Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                                   FontWeight="Medium" FontSize="12"/>
                        <TextBlock Text=" — "
                                   Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                                   Opacity="0.45" FontSize="12"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                                   Opacity="0.65" FontSize="12"/>
                    </StackPanel>

                    <!-- Minimize + Close -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Command="{Binding MinimizeCommand}"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                                Width="30" Height="34" Padding="0">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button Command="{Binding CloseCommand}"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                                Width="30" Height="34" Padding="0">
                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Main content ── -->
            <StackPanel Margin="14,6,14,12">

                <!-- Horizontal controls row -->
                <Grid Grid.IsSharedSizeScope="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>                            <!-- Record FAB -->
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="Selector"/> <!-- Connector -->
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="Selector"/> <!-- Microphone -->
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>                            <!-- Settings -->
                    </Grid.ColumnDefinitions>

                    <!-- Round record button -->
                    <Button Grid.Column="0"
                            Width="52" Height="52"
                            Padding="0"
                            VerticalAlignment="Center"
                            Command="{Binding ToggleRecordingCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="26"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Background"   Value="#EF5350"/>
                                        <Setter Property="BorderBrush"  Value="#EF5350"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <materialDesign:PackIcon Width="22" Height="22">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="Microphone"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Kind" Value="Stop"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsTranscribing}" Value="True">
                                            <Setter Property="Kind" Value="DotsHorizontal"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                    </Button>

                    <!-- Connector (profile) selector -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <materialDesign:PackIcon Kind="Api"
                                                     Width="13" Height="13"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,5,0"
                                                     Opacity="0.45"/>
                            <TextBlock Text="CONNECTOR"
                                       FontSize="10" FontWeight="Medium"
                                       Opacity="0.45"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding ActiveProfile}"
                                  DisplayMemberPath="Name"/>
                    </StackPanel>

                    <!-- Microphone selector -->
                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <materialDesign:PackIcon Kind="MicrophoneOutline"
                                                     Width="13" Height="13"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,5,0"
                                                     Opacity="0.45"/>
                            <TextBlock Text="MICROPHONE"
                                       FontSize="10" FontWeight="Medium"
                                       Opacity="0.45"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding AudioDevices}"
                                  SelectedItem="{Binding SelectedDevice}"
                                  DisplayMemberPath="Name"/>
                    </StackPanel>

                    <!-- Settings icon button -->
                    <Button Grid.Column="6"
                            VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding OpenSettingsCommand}"
                            ToolTip="Settings">
                        <materialDesign:PackIcon Kind="Cog" Width="22" Height="22"/>
                    </Button>
                </Grid>

                <!-- Error panel (below, second row) -->
                <Border CornerRadius="6" Padding="10,8" Margin="0,10,0,0"
                        Background="#B71C1C"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding ErrorMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="White"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Command="{Binding DismissErrorCommand}"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Foreground="White"
                                Width="24" Height="24" Padding="0"
                                VerticalAlignment="Top"
                                Margin="6,0,0,0">
                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
        </DockPanel>
    </Border>
</Window>
