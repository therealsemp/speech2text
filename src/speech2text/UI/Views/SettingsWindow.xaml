<Window x:Class="speech2text.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="560" Height="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main: profile list + form -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: profile list -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="＋" Command="{Binding AddProfileCommand}"    Width="28" Margin="0,0,4,0"/>
                    <Button Content="－" Command="{Binding DeleteProfileCommand}" Width="28"/>
                </StackPanel>
                <TextBlock Text="Profiles" FontWeight="SemiBold" DockPanel.Dock="Top" Margin="0,0,0,4"/>
                <ListBox ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         DisplayMemberPath="Name"/>
            </DockPanel>

            <!-- Right: profile form -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Profile form" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <TextBlock Text="Name" Foreground="#888888" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8"/>

                <TextBlock Text="API Key" Foreground="#888888" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding ProfileApiKey, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8"/>

                <TextBlock Text="Endpoint URL" Foreground="#888888" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding ProfileEndpointUrl, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8"/>

                <TextBlock Text="Language (BCP-47, e.g. fr, en-US)" Foreground="#888888" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding ProfileLanguage, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8"/>
            </StackPanel>
        </Grid>

        <!-- Bottom: hotkey + save -->
        <StackPanel Grid.Row="1">
            <Separator Margin="0,0,0,10"/>
            <DockPanel>
                <Button Content="Save" Command="{Binding SaveCommand}"
                        DockPanel.Dock="Right" Padding="16,4"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Global hotkey:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding HotkeyBinding, UpdateSourceTrigger=PropertyChanged}"
                             Width="120" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </StackPanel>

    </Grid>
</Window>
